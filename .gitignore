# Node modules
node_modules/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment variables
.env
.env.*

# Build folders
dist/
build/

# OS files (dot/system files)
.DS_Store
Thumbs.db

# IDE/editor folders
.vscode/
.idea/

